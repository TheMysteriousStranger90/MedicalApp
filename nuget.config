<?xml version="1.0" encoding="utf-8"?>

<configuration>
    <packageSources>
        <clear />
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    </packageSources>

    <packageSourceMapping>
        <packageSource key="nuget.org">
            <!-- Protobuf / gRPC -->
            <package pattern="Google.Protobuf" />
            <package pattern="Grpc.*" />

            <!-- ASP.NET Core / EF Core / Identity -->
            <package pattern="Microsoft.*" />

            <!-- OpenTelemetry -->
            <package pattern="OpenTelemetry" />
            <package pattern="OpenTelemetry.*" />

            <!-- Serilog -->
            <package pattern="Serilog" />
            <package pattern="Serilog.*" />

            <!-- Other -->
            <package pattern="AutoMapper" />
            <package pattern="Polly" />
        </packageSource>
    </packageSourceMapping>

    <packageRestore>
        <add key="enabled" value="True" />
        <add key="automatic" value="True" />
    </packageRestore>

    <bindingRedirects>
        <add key="skip" value="False" />
    </bindingRedirects>

    <config>
        <add key="globalPackagesFolder" value="%USERPROFILE%\.nuget\packages" />
    </config>
</configuration>